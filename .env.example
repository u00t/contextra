# Copy to .env and edit as needed. All values are optional.

# --- Database --------------------------------------------------------------
# Default is local SQLite. Uncomment to use Postgres (needs psycopg2-binary).
# DATABASE_URL=postgresql+psycopg2://user:pass@localhost:5432/contextra

# --- Storage ---------------------------------------------------------------
# CONTEXTRA_DATA_DIR=./data/raw

# --- AI / Semantic layer ---------------------------------------------------
# If set, low-confidence columns get LLM refinement. Leave blank for the
# fully-offline heuristic engine.
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Sample values inspected per column during profiling/semantics.
# CONTEXTRA_SAMPLE_SIZE=50
